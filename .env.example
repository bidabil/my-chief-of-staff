# ============================================================
# Chief of Staff - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================

# ─────────────────────────────────────────────────────────
# REQUIRED - Telegram Bot
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ─────────────────────────────────────────────────────────
# REQUIRED - Telegram Chat ID (pour le briefing matinal proactif)
# Trouvez votre chat ID : envoyez un message à @userinfobot sur Telegram
# ─────────────────────────────────────────────────────────
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─────────────────────────────────────────────────────────
# REQUIRED - 1min.ai Gateway (DeepSeek API)
# ─────────────────────────────────────────────────────────
ONE_MIN_AI_API_KEY=your-1min-ai-key-here

# ─────────────────────────────────────────────────────────
# REQUIRED - PostgreSQL
# ─────────────────────────────────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your-secure-password-min-16-chars
POSTGRES_DB=n8n

# ─────────────────────────────────────────────────────────
# REQUIRED - n8n Security
# ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=min-32-character-encryption-key-here
# Generate with: openssl rand -hex 32
N8N_USER_MANAGEMENT_JWT_SECRET=your-jwt-secret-min-32-chars

# ─────────────────────────────────────────────────────────
# REQUIRED - Gateway Security
# ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-min-32-chars
# Domaines autorisés à appeler le gateway (séparés par des virgules)
CORS_ORIGINS=https://your-domain.com

# ─────────────────────────────────────────────────────────
# OPTIONAL - Gateway Configuration
# ─────────────────────────────────────────────────────────
PERMIT_MODELS_FROM_SUBSET_ONLY=false
RATELIMIT_ENABLED=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────
# REQUIRED for remote deployments — public URL for Telegram webhooks
# Must be reachable from the internet (use your domain or public IP)
# ─────────────────────────────────────────────────────────
WEBHOOK_URL=https://your-domain.com

# ─────────────────────────────────────────────────────────
# OPTIONAL - n8n Configuration
# ─────────────────────────────────────────────────────────
# N8N_HOST=0.0.0.0
# N8N_PORT=5678
# N8N_PROTOCOL=http

# ─────────────────────────────────────────────────────────
# REQUIRED for production — Caddy TLS (HTTPS)
# Activate with: COMPOSE_PROFILES=tls docker compose up -d
# Or add COMPOSE_PROFILES=tls to your .env file
# ─────────────────────────────────────────────────────────
COMPOSE_PROFILES=tls
DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com
