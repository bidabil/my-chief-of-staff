# ============================================================
# Chief of Staff - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
#
# Organisation :
#   1. INFRASTRUCTURE  — commun à toutes les automatisations
#   2. GATEWAY         — accès au LLM (1min.ai / DeepSeek)
#   3. [AUTOMATION: …] — une section par automatisation ajoutée
# ============================================================

# ─────────────────────────────────────────────────────────
# INFRASTRUCTURE — PostgreSQL
# ─────────────────────────────────────────────────────────
POSTGRES_DB=chief_db
POSTGRES_USER=chief
# Min 16 characters — generate with: openssl rand -hex 16
POSTGRES_PASSWORD=your-secure-password-min-16-chars

# ─────────────────────────────────────────────────────────
# INFRASTRUCTURE — n8n Security
# ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=min-32-character-encryption-key-here
# Generate with: openssl rand -hex 32
N8N_USER_MANAGEMENT_JWT_SECRET=your-jwt-secret-min-32-chars

# ─────────────────────────────────────────────────────────
# INFRASTRUCTURE — Network
# ─────────────────────────────────────────────────────────
# Public URL of your server (used for Telegram webhooks)
WEBHOOK_URL=https://your-domain.com

# ─────────────────────────────────────────────────────────
# INFRASTRUCTURE — Caddy TLS (production only)
# Activate with: COMPOSE_PROFILES=tls in this file
# ─────────────────────────────────────────────────────────
COMPOSE_PROFILES=tls
DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com

# ─────────────────────────────────────────────────────────
# GATEWAY — 1min.ai (DeepSeek / LLM access)
# Get your key at: https://1min.ai → Settings → API Keys
# ─────────────────────────────────────────────────────────
ONE_MIN_AI_API_KEY=your-1min-ai-key-here
# Public URL of n8n — used by gateway for CORS. In dev: http://localhost:5678
CORS_ORIGINS=https://your-domain.com
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-min-32-chars

# Gateway tuning (optional — defaults work out of the box)
LOG_LEVEL=INFO
PERMIT_MODELS_FROM_SUBSET_ONLY=false
RATELIMIT_ENABLED=false

# ─────────────────────────────────────────────────────────
# [AUTOMATION: morning-briefing]
# Telegram bot that answers via DeepSeek + daily 7h00 briefing
# ─────────────────────────────────────────────────────────
# Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Your personal chat ID — get it from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─────────────────────────────────────────────────────────
# [AUTOMATION: <next-automation-name>]
# Short description of what this automation does
# ─────────────────────────────────────────────────────────
# Add your automation-specific secrets here
# Example:
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
