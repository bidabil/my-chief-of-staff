# ============================================================
# Environnement de développement local
# ============================================================
# Usage :
#   1. cp .env.dev .env          (première fois uniquement)
#   2. make dev                  (démarre le stack)
#
# ONE_MIN_AI_API_KEY et TELEGRAM_BOT_TOKEN doivent être
# remplacés par tes vraies valeurs pour tester LLM et bot.
# Les autres valeurs fonctionnent telles quelles en local.
# ============================================================

# ─────────────────────────────────────────────────────────
# 1min.ai Gateway — remplacer par ta vraie clé
# ─────────────────────────────────────────────────────────
ONE_MIN_AI_API_KEY=dev-replace-with-real-key

# ─────────────────────────────────────────────────────────
# PostgreSQL — valeurs fixes pour le dev local
# ─────────────────────────────────────────────────────────
POSTGRES_USER=chief
POSTGRES_PASSWORD=chief_dev_password_2026
POSTGRES_DB=chief_db

# ─────────────────────────────────────────────────────────
# n8n Security — valeurs fixes ok en dev (jamais en prod)
# ─────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=dev-encryption-key-32charslong0000
N8N_USER_MANAGEMENT_JWT_SECRET=dev-jwt-secret-32charslong000000

# ─────────────────────────────────────────────────────────
# Telegram — remplacer par ton vrai token pour tester le bot
# En dev : polling automatique, aucune URL publique requise
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=dev-replace-with-real-token
TELEGRAM_CHAT_ID=dev-replace-with-real-chat-id

# ─────────────────────────────────────────────────────────
# Gateway Security — valeurs fixes ok en dev (jamais en prod)
# ─────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-32charslong000000000
CORS_ORIGINS=http://localhost:5678,http://localhost:3000

# ─────────────────────────────────────────────────────────
# n8n — mode local (polling, pas de webhook public requis)
# ─────────────────────────────────────────────────────────
WEBHOOK_URL=http://localhost:5678
N8N_PROTOCOL=http
